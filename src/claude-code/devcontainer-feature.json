{
    "name": "Claude Code CLI",
    "id": "claude-code",
    "version": "2.1.0",
    "description": "Installs the Claude Code CLI globally using the native installer",
    "options": {
        "shareSession": {
            "type": "boolean",
            "default": false,
            "description": "Symlinks ~/.claude to /claude-host-config. Requires a bind mount in devcontainer.json."
        }
    },
    "postStartCommand": "/usr/local/bin/setup-claude-session",
    "documentationURL": "https://github.com/anthropics/devcontainer-features/tree/main/src/claude-code",
    "licenseURL": "https://github.com/anthropics/devcontainer-features/blob/main/LICENSE",
    "customizations": {
        "vscode": {
            "extensions": [
                "anthropic.claude-code"
            ]
        }
    }
}
